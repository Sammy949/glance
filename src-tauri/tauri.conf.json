{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "glance",
  "version": "0.1.0",
  "identifier": "com.sammy949.glance",
  "build": {
    "frontendDist": "frontend",
    "beforeDevCommand": "node src-tauri/build-web.mjs",
    "beforeBuildCommand": "node src-tauri/build-web.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "glance",
        "width": 1000,
        "height": 720,
        "minWidth": 480,
        "minHeight": 360,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Fast markdown viewer & quick editor",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/[email protected]",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Viewer"
      }
    ]
  }
}
